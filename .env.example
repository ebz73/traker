# Database
DATABASE_URL=postgresql://user:password@db:5432/pricetracker

# Chrome container CDP endpoint (internal Docker network — do not expose to host)
CHROME_CDP_URL=http://chrome:9222

# Scraper tuning
SCRAPE_MAX_ATTEMPTS=3
HTTP_FIRST_MAX_ATTEMPTS=3

# --- Proxy (disabled — uncomment and fill in to enable) ---
# Set this in the chrome container's environment to route Chrome through a proxy.
# PROXY_SERVER=http://user:pass@proxy-host:port
