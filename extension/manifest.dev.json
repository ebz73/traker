{
  "manifest_version": 3,
  "name": "TRAKER",
  "version": "1.0.0",
  "description": "Track prices across any online store",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://localhost/*",
        "https://127.0.0.1/*"
      ],
      "js": [
        "web_bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
